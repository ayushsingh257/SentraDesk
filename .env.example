# Environment Type (development / staging / production)
ENVIRONMENT=development

# Security Configurations
JWT_SECRET=super_secret_jwt_signing_key_for_development_purposes_only_change_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# FastAPI Config
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# PostgreSQL Database Config
POSTGRES_USER=ccgp_admin
POSTGRES_PASSWORD=ccgp_secure_password_2026
POSTGRES_DB=ccgp_governance
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://ccgp_admin:ccgp_secure_password_2026@db:5432/ccgp_governance

# Redis Cache Config
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# Object Storage Config (MinIO)
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minio_admin_user
MINIO_SECRET_KEY=minio_admin_secret_key_2026
MINIO_BUCKET_NAME=ccgp-evidence
MINIO_SECURE=false

# Vector DB Config (Qdrant)
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_URL=http://qdrant:6333

# AI & Machine Learning Configuration
MLFLOW_TRACKING_URI=http://mlflow:5000
HF_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# SMTP Configurations (Email Automation)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=alerts.ccgp@example.com
SMTP_PASSWORD=gmail_application_password
SMTP_FROM_EMAIL=alerts.ccgp@example.com
SMTP_FROM_NAME="CCGP Alert System"
