# ============================================================
# SentraDesk — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file.
# ============================================================

# --- Application ---
ENVIRONMENT=development  # development | testing | production
PROJECT_NAME="SentraDesk — SentraDesk"

# --- JWT Security ---
# Generate a strong secret: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=change_this_to_a_strong_random_secret_before_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- PostgreSQL ---
POSTGRES_USER=sentradesk_admin
POSTGRES_PASSWORD=sentradesk_secure_password_2026
POSTGRES_DB=sentradesk_governance
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
DATABASE_URL=postgresql://sentradesk_admin:sentradesk_secure_password_2026@127.0.0.1:5432/sentradesk_governance

# --- Redis ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_URL=redis://127.0.0.1:6379/0

# --- MinIO (Object Storage) ---
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=minio_admin_user
MINIO_SECRET_KEY=minio_admin_secret_key_2026
MINIO_BUCKET_NAME=sentradesk-evidence
MINIO_SECURE=false  # true in production with TLS

# --- Qdrant (Vector Database) ---
QDRANT_HOST=127.0.0.1
QDRANT_PORT=6333
QDRANT_URL=http://127.0.0.1:6333

# --- Celery (Background Jobs) ---
CELERY_BROKER_URL=redis://127.0.0.1:6379/1
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/2

# --- SMTP (Email) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=noreply@sentradesk.gov.in
SMTP_FROM_NAME=SentraDesk Platform

# --- IMAP (Incoming Email Listener) ---
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=complaints@sentradesk.gov.in
IMAP_PASSWORD=your_imap_password
IMAP_MAILBOX=INBOX

# --- Frontend (used by Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:8001

# --- Threat Intelligence APIs (optional) ---
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=
ALIENVAULT_OTX_KEY=

# --- CORS ---
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","http://localhost:3001","http://127.0.0.1:3001","http://localhost:3002","http://127.0.0.1:3002","http://localhost:3003","http://127.0.0.1:3003","http://localhost:3004","http://127.0.0.1:3004","http://localhost:3005","http://127.0.0.1:3005"]
FRONTEND_URL=http://localhost:3000
